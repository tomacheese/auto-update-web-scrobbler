{
  "name": "auto-update-web-scrobbler",
  "version": "1.0.0",
  "description": "Synchronize Web Scrobbler LevelDB file with fetch-youtube-bgm",
  "homepage": "https://github.com/tomacheese/auto-update-web-scrobbler",
  "bugs": {
    "url": "https://github.com/tomacheese/auto-update-web-scrobbler/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomacheese/auto-update-web-scrobbler.git"
  },
  "scripts": {
    "dev": "tsx watch ./src/main.ts",
    "start": "tsx ./src/main.ts",
    "package": "run-z clean compile packing",
    "packing": "ncc build ./dist/main.js -o output/ -m",
    "compile": "tsc -p .",
    "clean": "rimraf dist output",
    "fix:prettier": "prettier --write src",
    "lint:tsc": "tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "fix": "run-z fix:prettier fix:eslint",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:prettier": "prettier --check src",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.30",
    "@book000/node-utils": "1.24.167",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.3",
    "@vercel/ncc": "0.38.4",
    "eslint": "10.3.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.0",
    "jest-expect-message": "1.1.3",
    "level": "10.0.0",
    "lodash": "4.18.1",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "run-z": "2.1.0",
    "ts-jest": "29.4.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ]
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
